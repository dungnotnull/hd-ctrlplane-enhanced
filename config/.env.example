# ctrlplane-enhanced — Required Environment Variables
# Copy this file to .env and fill in your values

# ── Ctrlplane upstream ──────────────────────────────────────────────────────
CTRLPLANE_URL=http://localhost:3000
CTRLPLANE_API_KEY=your_ctrlplane_api_key_here

# ── Prometheus (for golden signal monitoring) ───────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── LLM API Keys ────────────────────────────────────────────────────────────
# Claude (primary reasoning engine)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (fallback provider)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (offline/air-gapped mode)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Override default models
# CLAUDE_MODEL=claude-opus-4-8
# OPENAI_MODEL=gpt-4o
# OLLAMA_MODEL=llama3

# ── GitHub (for Ctrlplane release tracking) ─────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Optional: Semantic Scholar API (rate limit lifted with key) ──────────────
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# ── Webhook notifications ────────────────────────────────────────────────────
# Slack webhook URL for rollback notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Storage paths ────────────────────────────────────────────────────────────
# MEMORY_DB_PATH=./data/ctrlplane_memory.db
# HF_CACHE_DIR=./models
